{
  "rewrites": [
    {
      "source": "/fr/:path*",
      "destination": "/fr/index.html"
    },
    {
      "source": "/en/:path*",
      "destination": "/en/index.html"
    },
    {
      "source": "/ru/:path*",
      "destination": "/ru/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
