<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirect to language folders if not already there
  # (This is handled by the root index.html JS router, but can be added here too)

  # For /fr/ folder
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^fr/.*$ fr/index.html [L]

  # For /en/ folder
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^en/.*$ en/index.html [L]

  # For /ru/ folder
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ru/.*$ ru/index.html [L]

  # Default fallback to root index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
